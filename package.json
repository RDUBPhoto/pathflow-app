{
  "name": "pathflow-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "postinstall": "node scripts/patch-stencil-empty-glob.mjs",
    "prebuild": "node scripts/patch-stencil-empty-glob.mjs",
    "start": "node scripts/dev-local.mjs",
    "start:demo": "node scripts/dev-local.mjs --seed-demo",
    "start:cloud": "ng serve --proxy-config proxy.conf.json",
    "start:local": "node scripts/dev-local.mjs",
    "dev:local": "node scripts/dev-local.mjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:unit:ci": "ng test --watch=false --browsers=ChromeHeadless --code-coverage --progress=false",
    "test:e2e": "playwright test",
    "test:e2e:hosted": "playwright test -c playwright.hosted.config.ts",
    "test:qa": "node scripts/run-qa.mjs",
    "qa:purge": "node scripts/purge-qa-data.mjs"
  },
  "private": true,
  "engines": {
    "node": ">=18 <20"
  },
  "dependencies": {
    "@angular/cdk": "^19.2.4",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@azure/storage-blob": "^12.28.0",
    "@daypilot/daypilot-lite-angular": "^5.3.1",
    "@ionic/angular": "^8.7.4",
    "ionicons": "^8.0.13",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.1",
    "@angular/cli": "^19.2.1",
    "@angular/compiler-cli": "^19.2.0",
    "@playwright/test": "^1.58.2",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "playwright": "^1.58.2",
    "typescript": "~5.7.2"
  }
}
