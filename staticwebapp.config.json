{
  "routes": [
    { "route": "/login", "allowedRoles": ["anonymous"] },
    { "route": "/register", "allowedRoles": ["authenticated"] },
    { "route": "/sms-opt-in", "allowedRoles": ["anonymous"] },
    { "route": "/api/widget/lead", "allowedRoles": ["anonymous"] },
    { "route": "/dashboard", "allowedRoles": ["authenticated"] },
    { "route": "/customers", "allowedRoles": ["authenticated"] },
    { "route": "/customers/*", "allowedRoles": ["authenticated"] },
    { "route": "/schedule", "allowedRoles": ["authenticated"] },
    { "route": "/inventory", "allowedRoles": ["authenticated"] },
    { "route": "/user-settings", "allowedRoles": ["authenticated"] },
    { "route": "/admin-settings", "allowedRoles": ["authenticated"] },
    { "route": "/forbidden", "allowedRoles": ["authenticated"] },
    { "route": "/api/*", "allowedRoles": ["authenticated"] }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/assets/*", "/.auth/*"]
  }
}
