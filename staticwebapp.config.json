{
  "routes": [
    {
      "route": "/login",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/signup",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/register",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/sms-opt-in",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/getRoles",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/widget/lead",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/access",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/brandingUpload",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/brandingUpload/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/quote-response",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/dashboard",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/customers",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/customers/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/schedule",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/inventory",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/user-settings",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/admin-settings",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/forbidden",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/.auth/*",
      "/assets/*",
      "/*.js",
      "/*.css",
      "/*.map",
      "/*.json",
      "/*.ico",
      "/*.svg",
      "/*.png",
      "/*.jpg",
      "/*.jpeg",
      "/*.webp",
      "/*.txt",
      "/browser/*"
    ]
  },
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/login"
    }
  },
  "auth": {
    "rolesSource": "/api/getRoles",
    "identityProviders": {
      "google": {
        "registration": {
          "clientIdSettingName": "GOOGLE_CLIENT_ID",
          "clientSecretSettingName": "GOOGLE_CLIENT_SECRET_APP_SETTING_NAME"
        }
      }
    }
  }
}
