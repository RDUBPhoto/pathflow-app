{
  "auth": {
    "identityProviders": {
      "customOpenIdConnectProviders": {
        "email": {
          "registration": {
            "clientIdSettingName": "EMAIL_OIDC_CLIENT_ID",
            "clientCredential": {
              "clientSecretSettingName": "EMAIL_OIDC_CLIENT_SECRET"
            },
            "openIdConnectConfiguration": {
              "wellKnownOpenIdConfiguration": "https://pathflowcustomers.ciamlogin.com/88152ab2-c1c2-42ca-be4f-1472aa5f8d08/v2.0/.well-known/openid-configuration"
            }
          },
          "login": {
            "nameClaimType": "name",
            "scopes": ["openid", "profile", "email"]
          }
        }
      }
    }
  },
  "routes": [
    { "route": "/login", "allowedRoles": ["anonymous"] },
    { "route": "/signup", "allowedRoles": ["anonymous"] },
    { "route": "/register", "allowedRoles": ["authenticated"] },
    { "route": "/sms-opt-in", "allowedRoles": ["anonymous"] },
    { "route": "/api/widget/lead", "allowedRoles": ["anonymous"] },
    { "route": "/api/access", "allowedRoles": ["anonymous"] },
    { "route": "/api/brandingUpload", "allowedRoles": ["anonymous"] },
    { "route": "/api/brandingUpload/*", "allowedRoles": ["anonymous"] },
    { "route": "/api/quote-response", "allowedRoles": ["anonymous"] },
    { "route": "/dashboard", "allowedRoles": ["authenticated"] },
    { "route": "/customers", "allowedRoles": ["authenticated"] },
    { "route": "/customers/*", "allowedRoles": ["authenticated"] },
    { "route": "/schedule", "allowedRoles": ["authenticated"] },
    { "route": "/inventory", "allowedRoles": ["authenticated"] },
    { "route": "/user-settings", "allowedRoles": ["authenticated"] },
    { "route": "/admin-settings", "allowedRoles": ["authenticated"] },
    { "route": "/forbidden", "allowedRoles": ["authenticated"] },
    { "route": "/api/*", "allowedRoles": ["authenticated"] }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/assets/*", "/.auth/*"]
  },
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/login"
    }
  }
}
